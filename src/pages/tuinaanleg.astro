---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import Gallery from '../components/Gallery.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { tuinaanlegFeatures as features } from '../data/services';
import { tuinaanlegImages } from '../config/images';

const pageUrl = new URL('/tuinaanleg', client.domain).toString();

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: 'Tuinaanleg & bestrating',
      serviceType: 'Tuinaanleg, bestrating, vlonders, trappen, plantenbakken en kunstgras',
      description: `${brand.name} legt opritten, terrassen, tuinpaden, vlonders, stenen trappen, plantenbakken en kunstgras of natuurgras aan in Papendrecht en de Drechtsteden.`,
      provider: { '@type': 'LocalBusiness', name: client.name, url: client.domain },
      areaServed: client.serviceAreas.map((name) => ({ '@type': 'City', name })),
      url: pageUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: client.domain },
        { '@type': 'ListItem', position: 2, name: 'Tuinaanleg & bestrating', item: pageUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: features.map((f) => ({
        '@type': 'Question',
        name: f.title,
        acceptedAnswer: { '@type': 'Answer', text: f.description },
      })),
    },
  ],
};
---

<BaseLayout
  title="Tuinaanleg & bestrating"
  description={`Tuinaanleg en bestrating: vlonders, stenen trappen, plantenbakken, kunstgras en natuurgras voor opritten, terrassen en tuinpaden in Papendrecht en de Drechtsteden. Vakkundig grondwerk door ${brand.name}. Vraag vrijblijvend uw offerte aan.`}
  schema={schema}
>
  <Header slot="header" />

  <Banner title="Tuinaanleg & bestrating" />

  <section class="pt-section pb-0">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-3xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-balance text-text">Uw buitenruimte tot in detail</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Of het nu gaat om een nieuwe oprit, een sfeervol terras, een houten vlonder, stenen trappen, gemetselde plantenbakken, het ophogen van uw tuin, een praktisch tuinpad of het aanleggen van kunstgras of natuurgras — bij Marlinco bent u aan het juiste adres. Wij leggen bestrating, vlonders, terrasplanken en grasvelden die niet alleen mooi ogen, maar ook jarenlang stevig blijven liggen. Met vakkundige aanleg en de juiste materialen creëren wij een buitenruimte waar u trots op kunt zijn.
        </p>
        <a
          href="/#contact"
          class="mt-6 inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
        >
          Bespreek uw project
        </a>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {features.map((feature) => (
          <div class="flex gap-5 rounded-lg border border-border bg-background p-6 shadow-sm">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-h3 font-semibold text-text">{feature.title}</h3>
              <p class="mt-2 text-text-muted leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Gallery
    images={tuinaanlegImages}
    ctaLabel=""
  />

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
