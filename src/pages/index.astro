---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import About from '../components/About.astro';
import Reviews from '../components/Reviews.astro';
import ProjectsByService from '../components/ProjectsByService.astro';
import ContactForm from '../components/ContactForm.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': `${client.domain}#business`,
      name: client.name,
      telephone: client.phoneForTel,
      email: client.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: client.address.lineOne,
        addressLocality: client.address.city,
        addressRegion: client.address.state,
        postalCode: client.address.zip,
        addressCountry: client.address.country,
      },
      url: client.domain,
      areaServed: client.serviceAreas.map((name) => ({ '@type': 'City', name })),
      sameAs: [client.socials.google],
    },
    {
      '@type': 'Organization',
      '@id': `${client.domain}#organization`,
      name: client.name,
      url: client.domain,
      logo: new URL('/og-image.jpg', client.domain).toString(),
      sameAs: [client.socials.google],
    },
  ],
};
---

<BaseLayout
  title={brand.name}
  description={brand.description}
  schema={schema}
>
  <Header slot="header" />

  <Hero />
  <TrustBar />
  <ProjectsByService />

  <Reviews />
  <About />
  <ContactForm />

  <Footer slot="footer" />
</BaseLayout>
