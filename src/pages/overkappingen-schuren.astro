---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import Gallery from '../components/Gallery.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { overkappingenFeatures as features } from '../data/services';
import { overkappingenImages } from '../config/images';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: features.map((f) => ({
    '@type': 'Question',
    name: f.title,
    acceptedAnswer: { '@type': 'Answer', text: f.description },
  })),
};
---

<BaseLayout
  title="Overkappingen & Schuren"
  description={`Overkappingen, veranda's, buitenkeukens, tuinhuizen en schuren op maat in Papendrecht en de Drechtsteden. Duurzaam vakwerk door ${brand.name} sinds 2009. Vraag een vrijblijvende offerte aan.`}
  schema={faqSchema}
>
  <Header slot="header" />

  <Banner title="Overkappingen & Schuren" />

  <section class="pt-section pb-0">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-3xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-balance text-text">Een overkapping, veranda of schuur op maat</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Wilt u het hele jaar door genieten van uw tuin? Of heeft u behoefte aan extra opslagruimte? Marlinco ontwerpt en bouwt overkappingen, veranda's, buitenkeukens, tuinhuizen en schuren die naadloos aansluiten bij uw woning. Met oog voor detail en gebruik van duurzame materialen realiseren wij constructies waar u jarenlang plezier van heeft.
        </p>
        <a
          href="/#contact"
          class="mt-6 inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
        >
          Bespreek uw project
        </a>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {features.map((feature) => (
          <div class="flex gap-5 rounded-lg border border-border bg-background p-6 shadow-sm">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-h3 font-semibold text-text">{feature.title}</h3>
              <p class="mt-2 text-text-muted leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Gallery
    images={overkappingenImages}
    ctaLabel=""
  />

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
