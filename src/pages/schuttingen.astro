---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import Gallery from '../components/Gallery.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { schuttingenFeatures as features } from '../data/services';
import { schuttingenImages } from '../config/images';

const pageUrl = new URL('/schuttingen', client.domain).toString();

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: 'Schuttingen',
      serviceType: 'Schuttingen plaatsen in hardhout, beton of composiet',
      description: `${brand.name} plaatst schuttingen in hardhout, beton en composiet in Papendrecht en de Drechtsteden — vakkundig gemonteerd en afgestemd op uw tuin.`,
      provider: { '@type': 'LocalBusiness', name: client.name, url: client.domain },
      areaServed: client.serviceAreas.map((name) => ({ '@type': 'City', name })),
      url: pageUrl,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: client.domain },
        { '@type': 'ListItem', position: 2, name: 'Schuttingen', item: pageUrl },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: features.map((f) => ({
        '@type': 'Question',
        name: f.title,
        acceptedAnswer: { '@type': 'Answer', text: f.description },
      })),
    },
  ],
};
---

<BaseLayout
  title="Schuttingen"
  description={`Schuttingen plaatsen in Papendrecht en de Drechtsteden — hardhout, beton of composiet. Vakkundig gemonteerd door ${brand.name}. Vraag een vrijblijvende offerte aan.`}
  schema={schema}
>
  <Header slot="header" />

  <Banner title="Schuttingen" />

  <section class="pt-section pb-0">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-3xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-balance text-text">Schuttingen voor elke tuin</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Een goede schutting biedt niet alleen privacy, maar draagt ook bij aan de sfeer en uitstraling van uw tuin. Marlinco plaatst schuttingen in diverse stijlen en materialen — altijd vakkundig en afgestemd op uw wensen. Of u nu kiest voor de warmte van hardhout, de robuustheid van beton of het gemak van composiet, wij zorgen voor een strak en duurzaam resultaat.
        </p>
        <a
          href="/#contact"
          class="mt-6 inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90"
        >
          Bespreek uw project
        </a>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {features.map((feature) => (
          <div class="flex gap-5 rounded-lg border border-border bg-background p-6 shadow-sm">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-h3 font-semibold text-text">{feature.title}</h3>
              <p class="mt-2 text-text-muted leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Gallery
    images={schuttingenImages}
    ctaLabel=""
  />

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
