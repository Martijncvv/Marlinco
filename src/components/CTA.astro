---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title = 'Een idee voor uw tuin?',
  description = 'Neem vrijblijvend contact met ons op — we kijken graag met u mee. Geen project is te groot of te klein.',
  buttonText = 'Bespreek uw project',
  buttonHref = '/#contact',
} = Astro.props;
---

<section class="relative overflow-hidden bg-primary py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-site px-4 text-center sm:px-6">
    <h2 class="font-heading text-h2 font-bold uppercase text-primary-fg">
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-primary-fg/80 leading-relaxed">
      {description}
    </p>

    <div class="mt-8 flex justify-center">
      <a
        href={buttonHref}
        class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        {buttonText}
      </a>
    </div>
  </div>
</section>
