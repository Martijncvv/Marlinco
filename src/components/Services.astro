---
interface ServiceItem {
  title: string;
  description: string;
  href?: string;
}

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  services?: ServiceItem[];
}

const icons = [
  // Overkappingen (house/roof)
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
  // Bestrating (grid/paving)
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z" />',
  // Schuttingen (shield/fence)
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />',
];

const {
  topper = 'Onze diensten',
  heading = 'Wat wij voor u doen',
  description = 'Van een sfeervolle overkapping tot een strakke oprit — wij leveren vakwerk met oog voor detail en persoonlijk advies.',
  services = [
    {
      title: 'Overkappingen & Schuren',
      description: 'Overkappingen, veranda\'s, buitenkeukens en schuren op maat — wij ontwerpen en bouwen constructies die perfect passen bij uw woning en tuin. Duurzame materialen en een nette afwerking zijn onze standaard.',
      href: '/overkappingen-schuren',
    },
    {
      title: 'Bestrating',
      description: 'Van opritten en terrassen tot tuinpaden, houten vlonders, stenen trappen en plantenbakken — wij leggen bestrating die er niet alleen mooi uitziet, maar ook jarenlang stevig blijft liggen. Altijd met de juiste afwatering en een strak resultaat.',
      href: '/bestrating',
    },
    {
      title: 'Schuttingen',
      description: 'Privacy en een mooie afscheiding gaan bij ons hand in hand. Wij plaatsen schuttingen in diverse stijlen en materialen, afgestemd op uw wensen en de uitstraling van uw tuin.',
      href: '/schuttingen',
    },
  ],
} = Astro.props;
---

<section class="bg-surface py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">{heading}</h2>
      <p class="mt-3 text-text-muted leading-relaxed">{description}</p>
    </div>

    <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {services.map((service, i) => (
        <li>
          <a
            href={service.href || '/#contact'}
            aria-label={`Meer over ${service.title}`}
            class="group flex h-full cursor-pointer flex-col rounded-lg border border-border bg-background p-6 shadow-sm transition-shadow duration-200 hover:shadow-md"
          >
            <div class="mb-4 flex size-12 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-fg">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[i % icons.length]} />
            </div>
            <h3 class="font-heading text-h3 font-semibold text-text">{service.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">{service.description}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors group-hover:text-accent">
              Bekijk projecten
              <span class="sr-only"> van {service.title}</span>
              <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
