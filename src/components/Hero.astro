---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { brand } from '../config/brand';
import { heroImage as localHeroImage } from '../config/images';

const PLACEHOLDER = 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1600&q=80';

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = 'Sinds 2009 in Papendrecht',
  heading = brand.tagline,
  description = 'Marlinco is uw betrouwbare partner voor alle klussen in en om huis. Van overkappingen en schuren tot bestrating, schuttingen en (kunst)gras — vakmanschap waar u op kunt rekenen.',
  ctaLabel = 'Bespreek uw project',
  ctaHref = '/#contact',
  imageSrc = localHeroImage ?? PLACEHOLDER,
  imageAlt = 'Sfeervolle achtertuin met klinkerbestrating, houten pergola\'s, schutting en kleurrijke beplanting',
} = Astro.props;
---

<section class="relative overflow-hidden bg-dark">
  <!-- Background image -->
  <div class="absolute inset-0" transition:name="hero-image">
    <Image
      src={imageSrc}
      alt={imageAlt}
      width={1600}
      height={1000}
      loading="eager"
      decoding="async"
      class="size-full object-cover"
    />
    <!-- Dark gradient for text legibility -->
    <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/65 to-dark/30" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent sm:hidden" aria-hidden="true"></div>
  </div>

  <!-- Foreground copy -->
  <div class="relative mx-auto max-w-site px-4 py-20 sm:px-6 sm:py-24 md:py-28 lg:py-32">
    <div class="max-w-2xl space-y-5 lg:space-y-6">
      {topper && (
        <span class="inline-block rounded-full bg-accent/15 px-4 py-1.5 text-topper font-bold uppercase tracking-widest text-accent ring-1 ring-accent/30">
          {topper}
        </span>
      )}

      <h1
        class="font-heading text-display font-bold uppercase leading-none tracking-tight text-white"
        transition:name="hero-heading"
      >
        {heading}
      </h1>

      <p class="max-w-lg text-lead leading-relaxed text-white/85">
        {description}
      </p>

      <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:gap-4">
        <a
          href={ctaHref}
          class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-lg transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {ctaLabel}
        </a>
      </div>
    </div>
  </div>
</section>
