---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { aboutImage as localAboutImage } from '../config/images';

const PLACEHOLDER = 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=900&q=80';

interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = 'Wie zijn wij',
  heading = 'Al sinds 2009 uw partner voor huis en tuin',
  body = [
    'Marlinco is opgericht in 2009 door M. van Veen in Papendrecht. Wat begon als een eenmansbedrijf is uitgegroeid tot een betrouwbare naam in de regio voor alle klussen in en om het huis.',
    'Wij geloven dat goede ideeën ontstaan door creatief denken. Daarom denken we graag met u mee om samen tot het beste resultaat te komen — van ontwerp tot oplevering.',
  ],
  benefits = [
    'Vakkundig en ervaren sinds 2009',
    'Persoonlijke aanpak en kort contact',
    'Kwaliteit waar u op kunt rekenen',
  ],
  ctaLabel = 'Meer over ons',
  ctaHref = '/wie-zijn-wij',
  imageSrc = localAboutImage ?? PLACEHOLDER,
  imageAlt = 'Marlinco aan het werk in een tuin',
} = Astro.props;
---

<section class="py-section">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">

    <!-- Image -->
    <div class="overflow-hidden rounded-lg shadow-lg">
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <!-- Content -->
    <div class="space-y-5">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="font-heading text-h2 font-bold uppercase text-text">{heading}</h2>

      {body.map((paragraph) => (
        <p class="text-text-muted leading-relaxed">{paragraph}</p>
      ))}

      <!-- Benefits list -->
      <ul class="space-y-3 pt-2" role="list">
        {benefits.map((benefit) => (
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 size-5 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-text">{benefit}</span>
          </li>
        ))}
      </ul>

      <div class="pt-2">
        <a
          href={ctaHref}
          class="inline-flex min-h-[44px] items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
