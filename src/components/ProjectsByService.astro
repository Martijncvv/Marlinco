---
import { Image } from 'astro:assets';
import { serviceProjects } from '../config/images';
---

<section class="py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">Ons werk</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">Recente projecten</h2>
      <p class="mt-3 text-text-muted leading-relaxed">
        Van een klein tuinpad tot een grote overkapping — groot of klein, wij leveren altijd hetzelfde vakwerk.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-6 lg:gap-8">
      {serviceProjects.map((group) => (
        <div class="group/col flex flex-col">
          <a href={group.href} class="block">
            <h3 class="font-heading text-2xl font-bold uppercase tracking-wide text-text transition-colors group-hover/col:text-primary sm:text-3xl">
              {group.service}
            </h3>
            <div class="mt-3 h-1 w-16 bg-accent transition-all duration-300 group-hover/col:w-24"></div>
          </a>

          <div class="mt-6 flex flex-col gap-3">
            {group.images.map(({ src, alt, location }, idx) => (
              <a
                href={group.href}
                class={`group relative block overflow-hidden rounded-lg bg-surface ${idx === 0 ? 'aspect-4/3' : 'aspect-video'}`}
                aria-label={`Bekijk ${group.service}`}
              >
                <Image
                  src={src}
                  alt={alt}
                  width={600}
                  height={idx === 0 ? 450 : 338}
                  loading="lazy"
                  decoding="async"
                  class="size-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <div class="pointer-events-none absolute inset-0 flex items-end bg-linear-to-t from-dark/70 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  <p class="p-3 text-sm font-medium text-white sm:p-4">
                    {alt}{location && ` · ${location}`}
                  </p>
                </div>
              </a>
            ))}
          </div>

          <a
            href={group.href}
            class="mt-5 inline-flex items-center gap-2 self-start font-bold text-primary transition-all hover:gap-3"
          >
            Bekijk {group.service.toLowerCase()}
            <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
