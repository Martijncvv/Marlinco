---
import { client } from '../data/client';
---

<section id="contact" class="bg-surface py-section scroll-mt-20">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:gap-14">

      <!-- Form -->
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Stuur ons een bericht</h2>
        <p class="mt-2 mb-8 text-text-muted">
          Vul het formulier in voor een vrijblijvende reactie, of bel of WhatsApp ons direct.
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contact/success"
          class="flex flex-col gap-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>Laat dit leeg: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Naam <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">E-mail <span class="text-accent" aria-hidden="true">*</span></span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Telefoonnummer</span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              inputmode="tel"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Bericht <span class="text-accent" aria-hidden="true">*</span></span>
            <textarea
              name="message"
              rows="5"
              required
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            Verstuur bericht
          </button>
        </form>
      </div>

      <!-- Contact info sidebar -->
      <aside class="space-y-8 lg:col-span-2">
        <div>
          <h3 class="font-heading text-lg font-semibold text-text">Bel ons</h3>
          <a href={`tel:${client.phoneForTel}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.phoneFormatted}
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">WhatsApp</h3>
          <a
            href={`https://wa.me/${client.phoneForTel.replace(/[-\s]/g, '').replace(/^0/, '31')}?text=Hallo%2C%20ik%20heb%20een%20vraag%20over%20jullie%20diensten.`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary"
          >
            Stuur een bericht
          </a>
        </div>

        <div>
          <h3 class="font-heading text-lg font-semibold text-text">E-mail</h3>
          <a href={`mailto:${client.email}`} class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary">
            {client.email}
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>
